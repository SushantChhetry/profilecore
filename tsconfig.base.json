{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowJs": false,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["apps/web/*"],
      "@profilecore/profile-schema": ["packages/profile-schema/src/index.ts"],
      "@profilecore/profile-schema/*": ["packages/profile-schema/src/*"]
    }
  }
}
